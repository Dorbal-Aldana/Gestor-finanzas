# Supabase (públicos)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Supabase (servidor; no exponer)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Mistral AI (resumen financiero)
MISTRAL_API_KEY=
# Opcional: mistral-small-latest | mistral-large-latest
# MISTRAL_MODEL=mistral-small-latest

# PostHog (analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Lemon Squeezy (SaaS)
# Secreto del webhook (Lemon → tu app)
LEMON_SQUEEZY_WEBHOOK_SECRET=
# API key privada (Lemon API) para cancelar suscripciones desde la app
LEMON_SQUEEZY_API_KEY=
# URL pública del checkout del variant (Share → Checkout link), ej. https://TU_TIENDA.lemonsqueezy.com/checkout/buy/XXXX
NEXT_PUBLIC_LEMON_SQUEEZY_CHECKOUT_URL=
# Solo desarrollo: desbloquea IA y PDF para todos (no usar en producción)
# SAAS_DEV_UNLOCK=1
# Pro sin Lemon: uno o varios usuarios (separados por coma). Usa el UUID de Auth o el email.
# SAAS_COMPLIMENTARY_USER_IDS=a1b2c3d4-e5f6-7890-abcd-ef1234567890
# SAAS_COMPLIMENTARY_EMAILS=founder@tuempresa.com,colaborador@ejemplo.org

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
